@model AnlamEditViewModel
@{
    ViewData["title"] = "Anlam Düzenle";
}

<div class="d-flex align-items-center mb-6">
    <a asp-action="Detail" asp-route-id="@Model.MaddeBasiId" class="btn btn-outline-secondary me-3">
        <i class="ri-arrow-left-line"></i>
    </a>
    <div>
        <h4 class="mb-1">Anlam #@Model.Numara Düzenle</h4>
        <p class="text-muted mb-0">
            <strong>@Model.Kelime</strong> → Anlam @Model.Numara
        </p>
    </div>
</div>

<div class="row">
    <div class="col-md-10 col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="AnlamDuzenle" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="MaddeBasiId" />
                    <input type="hidden" asp-for="Numara" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label asp-for="KelimeTuruId" class="form-label"></label>
                            <select asp-for="KelimeTuruId" asp-items="Model.KelimeTurleri" class="form-select">
                                <option value="">-- Seçin --</option>
                            </select>
                            <span asp-validation-for="KelimeTuruId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BicimId" class="form-label"></label>
                            <select asp-for="BicimId" asp-items="Model.Bicimler" class="form-select">
                                <option value="">-- Seçin (opsiyonel) --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="DuzeyId" class="form-label"></label>
                            <select asp-for="DuzeyId" asp-items="Model.Duzeyler" class="form-select">
                                <option value="">-- Seçin (opsiyonel) --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Tanim" class="form-label"></label>
                        <textarea asp-for="Tanim" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Tanim" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="OrnekCumlelerText" class="form-label"></label>
                        <textarea asp-for="OrnekCumlelerText" class="form-control" rows="4"
                                  placeholder="Her satıra bir örnek cümle yazın"></textarea>
                        <div class="form-text">Her satıra bir örnek cümle yazın.</div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="ri-save-line me-1"></i> Güncelle
                    </button>
                    <a asp-action="Detail" asp-route-id="@Model.MaddeBasiId"
                       class="btn btn-outline-secondary ms-2">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>
