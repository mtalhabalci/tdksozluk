@model MedyaUploadViewModel
@{
    ViewData["title"] = "Medya Yükle";
}

<div class="d-flex align-items-center mb-6">
    <a asp-action="Detail" asp-route-id="@Model.MaddeBasiId" class="btn btn-outline-secondary me-3">
        <i class="ri-arrow-left-line"></i>
    </a>
    <div>
        <h4 class="mb-1">Medya Yükle</h4>
        <p class="text-muted mb-0">
            <strong>@Model.Kelime</strong> için görsel veya ses dosyası yükleyin
        </p>
    </div>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="MedyaYukle" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="MaddeBasiId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="DosyaTipi" class="form-label"></label>
                        <select asp-for="DosyaTipi" class="form-select" id="dosyaTipi">
                            <option value="">-- Seçin --</option>
                            <option value="gorsel">Görsel (JPG, PNG, GIF, WebP, SVG)</option>
                            <option value="ses">Ses (MP3, WAV, OGG, M4A)</option>
                        </select>
                        <span asp-validation-for="DosyaTipi" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Dosya" class="form-label"></label>
                        <input asp-for="Dosya" type="file" class="form-control" id="dosyaInput" />
                        <span asp-validation-for="Dosya" class="text-danger"></span>
                        <div class="form-text">Maks. 25 MB</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Aciklama" class="form-label"></label>
                        <input asp-for="Aciklama" class="form-control" placeholder="Opsiyonel açıklama" />
                    </div>

                    <!-- Önizleme -->
                    <div id="previewArea" class="mb-4 d-none">
                        <label class="form-label">Önizleme</label>
                        <div id="imagePreview" class="d-none">
                            <img id="previewImg" src="#" alt="Önizleme" class="img-fluid rounded"
                                 style="max-height: 300px" />
                        </div>
                        <div id="audioPreview" class="d-none">
                            <audio id="previewAudio" controls class="w-100"></audio>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="ri-upload-line me-1"></i> Yükle
                    </button>
                    <a asp-action="Detail" asp-route-id="@Model.MaddeBasiId"
                       class="btn btn-outline-secondary ms-2">İptal</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script>
        var dosyaInput = document.getElementById('dosyaInput');
        var dosyaTipi = document.getElementById('dosyaTipi');
        var previewArea = document.getElementById('previewArea');
        var imagePreview = document.getElementById('imagePreview');
        var audioPreview = document.getElementById('audioPreview');
        var previewImg = document.getElementById('previewImg');
        var previewAudio = document.getElementById('previewAudio');

        dosyaTipi.addEventListener('change', function () {
            if (this.value === 'gorsel') {
                dosyaInput.accept = '.jpg,.jpeg,.png,.gif,.webp,.svg';
            } else if (this.value === 'ses') {
                dosyaInput.accept = '.mp3,.wav,.ogg,.m4a';
            } else {
                dosyaInput.accept = '';
            }
        });

        dosyaInput.addEventListener('change', function () {
            previewArea.classList.add('d-none');
            imagePreview.classList.add('d-none');
            audioPreview.classList.add('d-none');

            if (this.files && this.files[0]) {
                var file = this.files[0];
                var url = URL.createObjectURL(file);

                if (file.type.startsWith('image/')) {
                    previewImg.src = url;
                    imagePreview.classList.remove('d-none');
                    previewArea.classList.remove('d-none');
                } else if (file.type.startsWith('audio/')) {
                    previewAudio.src = url;
                    audioPreview.classList.remove('d-none');
                    previewArea.classList.remove('d-none');
                }
            }
        });
    </script>
}
