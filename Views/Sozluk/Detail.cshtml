@model MaddeBasiDetailViewModel
@{
    ViewData["title"] = Model.Kelime;
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <div class="d-flex align-items-center">
        <a asp-action="Index" class="btn btn-outline-secondary me-3">
            <i class="ri-arrow-left-line"></i>
        </a>
        <div>
            <h4 class="mb-1">@Model.Kelime</h4>
            <p class="text-muted mb-0">
                <span class="badge bg-label-info">@Model.TemaAd</span>
                <span class="ms-1">@Model.KonuAd</span>
            </p>
        </div>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
    {
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary me-2">
                <i class="ri-edit-line me-1"></i> Düzenle
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                  onsubmit="return confirm('Bu madde başını ve tüm anlamlarını silmek istediğinize emin misiniz?')">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="ri-delete-bin-line me-1"></i> Sil
                </button>
            </form>
        </div>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible mb-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- Sol: Bilgi + Anlamlar -->
    <div class="col-lg-8">
        <!-- Bilgi Kartı -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row text-muted small">
                    <div class="col-sm-4">
                        <i class="ri-user-line me-1"></i> <strong>Ekleyen:</strong> @Model.OlusturanAd
                    </div>
                    <div class="col-sm-4">
                        <i class="ri-calendar-line me-1"></i> <strong>Oluşturulma:</strong>
                        @Model.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")
                    </div>
                    <div class="col-sm-4">
                        <i class="ri-refresh-line me-1"></i> <strong>Güncelleme:</strong>
                        @Model.GuncellemeTarihi.ToString("dd.MM.yyyy HH:mm")
                    </div>
                </div>
            </div>
        </div>

        <!-- Anlamlar -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Anlamlar (@Model.Anlamlar.Count)</h5>
            @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
            {
                <a asp-action="AnlamEkle" asp-route-maddeId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="ri-add-line me-1"></i> Anlam Ekle
                </a>
            }
        </div>

        @if (!Model.Anlamlar.Any())
        {
            <div class="card">
                <div class="card-body text-center text-muted py-5">
                    <i class="ri-file-text-line ri-3x mb-2 d-block"></i>
                    <p class="mb-2">Henüz anlam eklenmemiş.</p>
                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <a asp-action="AnlamEkle" asp-route-maddeId="@Model.Id" class="btn btn-sm btn-outline-primary">
                            İlk anlamı ekle
                        </a>
                    }
                </div>
            </div>
        }

        @foreach (var anlam in Model.Anlamlar)
        {
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center py-3">
                    <div>
                        <span class="badge bg-label-secondary me-2">@anlam.Numara</span>
                        <span class="badge"
                              style="background-color: @anlam.KelimeTuruRenk; color: #fff">@anlam.KelimeTuruAd</span>
                        @if (!string.IsNullOrEmpty(anlam.BicimAd))
                        {
                            <span class="badge bg-label-warning ms-1">@anlam.BicimAd</span>
                        }
                        @if (!string.IsNullOrEmpty(anlam.DuzeyAd))
                        {
                            <span class="badge bg-label-info ms-1">@anlam.DuzeyAd</span>
                        }
                    </div>
                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <div>
                            <a asp-action="AnlamDuzenle" asp-route-id="@anlam.Id" class="btn btn-xs btn-outline-primary me-1"
                                   title="Düzenle">
                                <i class="ri-edit-line"></i>
                            </a>
                            <form asp-action="AnlamSil" asp-route-id="@anlam.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu anlamı silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-xs btn-outline-danger" title="Sil">
                                    <i class="ri-delete-bin-line"></i>
                                </button>
                            </form>
                        </div>
                    }
                </div>
                <div class="card-body">
                    <p class="mb-2">@anlam.Tanim</p>

                    @if (anlam.OrnekCumleler.Any())
                    {
                        <div class="mt-3 ps-3 border-start border-primary border-3">
                            @foreach (var ornek in anlam.OrnekCumleler)
                            {
                                <p class="text-muted fst-italic mb-1">
                                    <i class="ri-double-quotes-l me-1"></i>@ornek
                                </p>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Sağ: Medya -->
    <div class="col-lg-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Medya</h5>
            @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
            {
                <a asp-action="MedyaYukle" asp-route-maddeId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="ri-upload-line me-1"></i> Yükle
                </a>
            }
        </div>

        @{
            var gorseller = Model.Medyalar.Where(m => m.DosyaTipi == "gorsel").ToList();
            var sesler = Model.Medyalar.Where(m => m.DosyaTipi == "ses").ToList();
        }

        @if (!Model.Medyalar.Any())
        {
            <div class="card">
                <div class="card-body text-center text-muted py-4">
                    <i class="ri-image-line ri-2x mb-2 d-block"></i>
                    <p class="mb-0 small">Medya yüklenmemiş</p>
                </div>
            </div>
        }

        @if (gorseller.Any())
        {
            <div class="card mb-3">
                <div class="card-header py-3">
                    <h6 class="mb-0"><i class="ri-image-line me-1"></i> Görseller (@gorseller.Count)</h6>
                </div>
                <div class="card-body">
                    @foreach (var g in gorseller)
                    {
                        <div class="mb-3 position-relative">
                            <img src="@g.DosyaYolu" alt="@g.Aciklama" class="img-fluid rounded" />
                            @if (!string.IsNullOrEmpty(g.Aciklama))
                            {
                                <p class="text-muted small mt-1 mb-0">@g.Aciklama</p>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                            {
                                <form asp-action="MedyaSil" asp-route-id="@g.Id" method="post"
                                      class="position-absolute top-0 end-0 m-1"
                                      onsubmit="return confirm('Bu görseli silmek istediğinize emin misiniz?')">
                                    <button type="submit" class="btn btn-xs btn-danger rounded-circle">
                                        <i class="ri-close-line"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        @if (sesler.Any())
        {
            <div class="card mb-3">
                <div class="card-header py-3">
                    <h6 class="mb-0"><i class="ri-volume-up-line me-1"></i> Ses Dosyaları (@sesler.Count)</h6>
                </div>
                <div class="card-body">
                    @foreach (var s in sesler)
                    {
                        <div class="mb-3 d-flex align-items-center justify-content-between">
                            <div class="flex-grow-1 me-2">
                                <audio controls class="w-100">
                                    <source src="@s.DosyaYolu" />
                                </audio>
                                @if (!string.IsNullOrEmpty(s.Aciklama))
                                {
                                    <p class="text-muted small mt-1 mb-0">@s.Aciklama</p>
                                }
                            </div>
                            @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                            {
                                <form asp-action="MedyaSil" asp-route-id="@s.Id" method="post"
                                      onsubmit="return confirm('Bu ses dosyasını silmek istediğinize emin misiniz?')">
                                    <button type="submit" class="btn btn-xs btn-outline-danger">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
