@{
  TempData.Keep("appName");
  TempData.Keep("productPage");
  TempData.Keep("documentation");
  TempData.Keep("menuHorizontal");
  string? currentPage = ViewContext.HttpContext.Request.Path;
}

<!-- Menu -->
@* ! Do this simple *@
<aside id="layout-menu" class="layout-menu menu-vertical menu">

  @* ! Hide app brand if navbar-full *@
  <div
    class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="Home" asp-action="Index" class="app-brand-link">
      <span class="app-brand-logo demo">
        @await Html.PartialAsync("../_Partials/_Macros")
      </span>
      <span class="app-brand-text demo menu-text fw-semibold ms-2">@TempData.Peek("appName")</span>
    </a>

    <a href="javascript:void(0);" class="layout-menu-toggle menu-link text-large ms-auto">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path
        d="M8.47365 11.7183C8.11707 12.0749 8.11707 12.6531 8.47365 13.0097L12.071 16.607C12.4615 16.9975 12.4615 17.6305 12.071 18.021C11.6805 18.4115 11.0475 18.4115 10.657 18.021L5.83009 13.1941C5.37164 12.7356 5.37164 11.9924 5.83009 11.5339L10.657 6.707C11.0475 6.31653 11.6805 6.31653 12.071 6.707C12.4615 7.09747 12.4615 7.73053 12.071 8.121L8.47365 11.7183Z"
        fill-opacity="0.9" />
        <path
        d="M14.3584 11.8336C14.0654 12.1266 14.0654 12.6014 14.3584 12.8944L18.071 16.607C18.4615 16.9975 18.4615 17.6305 18.071 18.021C17.6805 18.4115 17.0475 18.4115 16.657 18.021L11.6819 13.0459C11.3053 12.6693 11.3053 12.0587 11.6819 11.6821L16.657 6.707C17.0475 6.31653 17.6805 6.31653 18.071 6.707C18.4615 7.09747 18.4615 7.73053 18.071 8.121L14.3584 11.8336Z"
        fill-opacity="0.4" />
      </svg>
    </a>
  </div>

  <div class="menu-inner-shadow"></div>

  @* Sözlük veri giriş menüsü *@
  <ul class="menu-inner py-1">

    <li class='menu-item@(currentPage == "/" ? " active" : "")'>
      <a asp-controller="Home" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base ri ri-home-smile-line"></i>
        <div>Ana Sayfa</div>
      </a>
    </li>

    @if (SignInManager.IsSignedIn(User))
    {
      <li class="menu-header mt-5">
        <span class="menu-header-text">Sözlük</span>
      </li>

      <li class='menu-item@(currentPage != null && currentPage.StartsWith("/Sozluk") ? " active open" : "")'>
        <a href="javascript:void(0);" class="menu-link menu-toggle">
          <i class="menu-icon icon-base ri ri-book-2-line"></i>
          <div>Sözlük</div>
        </a>
        <ul class="menu-sub">
          <li class='menu-item@(currentPage == "/Sozluk" ? " active" : "")'>
            <a asp-controller="Sozluk" asp-action="Index" class="menu-link">
              <div>Madde Başları</div>
            </a>
          </li>
          <li class='menu-item@(currentPage != null && currentPage.StartsWith("/Sozluk/Browse") ? " active" : "")'>
            <a asp-controller="Sozluk" asp-action="Browse" class="menu-link">
              <div>Gözat</div>
            </a>
          </li>
          @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
          {
            <li class='menu-item@(currentPage == "/Sozluk/Create" ? " active" : "")'>
              <a asp-controller="Sozluk" asp-action="Create" class="menu-link">
                <div>Yeni Madde Ekle</div>
              </a>
            </li>
          }
        </ul>
      </li>

      @if (User.IsInRole("Admin"))
      {
        <li class="menu-header mt-5">
          <span class="menu-header-text">Yönetim</span>
        </li>

        <li class='menu-item@(currentPage != null && currentPage.StartsWith("/Admin") ? " active open" : "")'>
          <a href="javascript:void(0);" class="menu-link menu-toggle">
            <i class="menu-icon icon-base ri ri-settings-3-line"></i>
            <div>Yönetim</div>
          </a>
          <ul class="menu-sub">
            <li class='menu-item@(currentPage == "/Admin/Users" ? " active" : "")'>
              <a asp-controller="Admin" asp-action="Users" class="menu-link">
                <div>Kullanıcılar</div>
              </a>
            </li>
            <li class='menu-item@(currentPage == "/Admin/Temalar" ? " active" : "")'>
              <a asp-controller="Admin" asp-action="Temalar" class="menu-link">
                <div>Temalar</div>
              </a>
            </li>
            <li class='menu-item@(currentPage == "/Admin/Konular" ? " active" : "")'>
              <a asp-controller="Admin" asp-action="Konular" class="menu-link">
                <div>Konular</div>
              </a>
            </li>
            <li class='menu-item@(currentPage == "/Admin/KelimeTurleri" ? " active" : "")'>
              <a asp-controller="Admin" asp-action="KelimeTurleri" class="menu-link">
                <div>Kelime Türleri</div>
              </a>
            </li>
            <li class='menu-item@(currentPage == "/Admin/Bicimler" ? " active" : "")'>
              <a asp-controller="Admin" asp-action="Bicimler" class="menu-link">
                <div>Biçemler</div>
              </a>
            </li>
            <li class='menu-item@(currentPage != null && currentPage.StartsWith("/Export") ? " active" : "")'>
              <a asp-controller="Export" asp-action="Index" class="menu-link">
                <div>Dışa Aktar</div>
              </a>
            </li>
          </ul>
        </li>
      }

      <li class="menu-header mt-5">
        <span class="menu-header-text">Hesap</span>
      </li>

      <li class="menu-item">
        <form asp-action="Logout" asp-controller="Account" method="post" id="logoutForm">
          <a href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();" class="menu-link">
            <i class="menu-icon icon-base ri ri-logout-box-r-line"></i>
            <div>Çıkış Yap</div>
          </a>
        </form>
      </li>
    }
  </ul>

</aside>
<!-- / Menu -->
