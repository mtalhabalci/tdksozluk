@model List<AspnetCoreMvcStarter.Models.Tema>
@{
    ViewData["title"] = "Temalar";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <div>
        <h4 class="mb-1">Temalar</h4>
        <p class="text-muted mb-0">Sözlükteki üst kategorileri yönetin</p>
    </div>
    <a asp-action="TemaEkle" class="btn btn-primary">
        <i class="ri-add-line me-1"></i> Yeni Tema
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible mb-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Tema Adı</th>
                    <th>Konu Sayısı</th>
                    <th class="text-center" style="width: 150px">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-5">Henüz tema eklenmemiş.</td>
                    </tr>
                }
                @foreach (var tema in Model)
                {
                    <tr>
                        <td class="fw-medium">@tema.Ad</td>
                        <td>
                            <a asp-action="Konular" asp-route-temaId="@tema.Id" class="text-primary">
                                Konuları Gör →
                            </a>
                        </td>
                        <td class="text-center">
                            <a asp-action="TemaDuzenle" asp-route-id="@tema.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="ri-edit-line"></i>
                            </a>
                            <form asp-action="TemaSil" asp-route-id="@tema.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu temayı ve altındaki tüm konuları silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                    class="ri-delete-bin-line"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
