@model AspnetCoreMvcStarter.Models.KelimeTuru
@{
    ViewData["title"] = "Yeni Kelime Türü Ekle";
}

<div class="row">
    <div class="col-xl-6 col-lg-8 col-md-10 mx-auto">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Yeni Kelime Türü Ekle</h5>
            </div>
            <div class="card-body">
                <form asp-action="KelimeTuruEkle" method="post">
                    <div class="mb-4">
                        <label asp-for="Ad" class="form-label">Tür Adı</label>
                        <input asp-for="Ad" class="form-control" placeholder="Örn: İsim" autofocus />
                        <span asp-validation-for="Ad" class="text-danger"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Renk" class="form-label">Renk (HEX)</label>
                        <div class="d-flex align-items-center gap-3">
                            <input asp-for="Renk" class="form-control" style="max-width: 150px;" id="renkInput" />
                            <input type="color" id="renkPicker" value="@Model.Renk"
                                   class="form-control form-control-color" style="width: 50px; height: 38px;"
                                   onchange="document.getElementById('renkInput').value = this.value" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Ekle</button>
                        <a asp-action="KelimeTurleri" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
