@model List<AspnetCoreMvcStarter.Models.Bicim>
@{
    ViewData["title"] = "Biçemler";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <div>
        <h4 class="mb-1">Biçemler</h4>
        <p class="text-muted mb-0">Mecaz, argo, halk ağzı gibi biçem türlerini yönetin</p>
    </div>
    <a asp-action="BicimEkle" class="btn btn-primary">
        <i class="ri-add-line me-1"></i> Yeni Biçem
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible mb-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Biçem Adı</th>
                    <th class="text-center" style="width: 150px">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="2" class="text-center text-muted py-5">Henüz biçem eklenmemiş.</td>
                    </tr>
                }
                @foreach (var b in Model)
                {
                    <tr>
                        <td class="fw-medium">@b.Ad</td>
                        <td class="text-center">
                            <a asp-action="BicimDuzenle" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="ri-edit-line"></i>
                            </a>
                            <form asp-action="BicimSil" asp-route-id="@b.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu biçemi silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                    class="ri-delete-bin-line"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
