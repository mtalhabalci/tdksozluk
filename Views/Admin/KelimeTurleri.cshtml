@model List<AspnetCoreMvcStarter.Models.KelimeTuru>
@{
    ViewData["title"] = "Kelime Türleri";
}

<div class="d-flex justify-content-between align-items-center mb-6">
    <div>
        <h4 class="mb-1">Kelime Türleri</h4>
        <p class="text-muted mb-0">İsim, sıfat, fiil gibi kelime türlerini ve renklerini yönetin</p>
    </div>
    <a asp-action="KelimeTuruEkle" class="btn btn-primary">
        <i class="ri-add-line me-1"></i> Yeni Kelime Türü
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible mb-4" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Kelime Türü</th>
                    <th>Renk</th>
                    <th>Önizleme</th>
                    <th class="text-center" style="width: 150px">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">Henüz kelime türü eklenmemiş.</td>
                    </tr>
                }
                @foreach (var kt in Model)
                {
                    <tr>
                        <td class="fw-medium">@kt.Ad</td>
                        <td><code>@kt.Renk</code></td>
                        <td>
                            <span class="badge" style="background-color: @kt.Renk; color: #fff;">@kt.Ad</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="KelimeTuruDuzenle" asp-route-id="@kt.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                <i class="ri-edit-line"></i>
                            </a>
                            <form asp-action="KelimeTuruSil" asp-route-id="@kt.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Bu kelime türünü silmek istediğinize emin misiniz?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                    class="ri-delete-bin-line"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
